            { "position": [-8,  4, -12], "scale": [1.8, 8, 1.2] },
            { "position": [-5,  3.5, -10], "scale": [1.5, 7, 1.0] },
            { "position": [ 5,  4.2, -11], "scale": [2.0, 8.4, 1.3] },
            { "position": [ 9,  3,   -13], "scale": [1.6, 6, 0.9] },
