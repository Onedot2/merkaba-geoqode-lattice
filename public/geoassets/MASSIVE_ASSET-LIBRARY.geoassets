    "quantum_field": {
      "id": "quantum_field",
      "title": "Quantum Field Visualiser",
      "logline": "Walk through quantum field fluctuations. Observe wave function collapse. Navigate probability clouds.",
      "palette": "quantum",
      "sound": "ambient_741hz",
      "narrativeBeats": [
        { "trigger": "enter",  "text": "You are inside a quantum field.\nEvery particle exists as probability — not position.", "durationMs": 7000 },
        { "trigger": "step_1", "text": "The act of observation collapses the wave function.\nLook at any node — it stabilises.", "durationMs": 8000 },
        { "trigger": "step_2", "text": "At Planck scale, space itself fluctuates.\nYou are not standing on matter. You are standing on probability.", "durationMs": 8000 }
      ],
      "environment": {
        "sky": { "color": "#030010" },
        "fog": { "color": "#030010", "density": 0.01 }
