{
  "_meta": {
    "format": "geoassets/v1",
    "name": "MASSIVE_ASSET-LIBRARY",
    "abbrev": "MAL",
    "version": "1.0.0",
    "created": "2026-05-05",
    "author": "AIOS / Brains4Ai",
    "architecture": "8→26→48:480",
    "phi": 1.618,
    "psi": 1.414,
    "baseHz": 72,
    "description": "Complete cinematic VR scene asset library for AIOS VR Platform. Each geo-asset is a fully described 3D element — geometry, material, position, animation, audio, narrative role — composable into complete immersive scenes by mal-loader.js.",
    "loaderScript": "/public/geoassets/mal-loader.js",
    "license": "AIOS-Internal — not for redistribution"
  },

