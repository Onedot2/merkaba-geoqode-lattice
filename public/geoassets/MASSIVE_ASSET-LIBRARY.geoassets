  "materials": {
    "code_rain_green":   { "color": "#00ff41", "emissive": "#00cc33", "emissiveIntensity": 0.6, "opacity": 0.92, "metalness": 0.0, "roughness": 1.0 },
    "code_rain_dim":     { "color": "#003b00", "emissive": "#001a00", "emissiveIntensity": 0.3, "opacity": 0.45 },
    "console_dark":      { "color": "#060d06", "emissive": "#000000", "metalness": 0.8, "roughness": 0.2, "opacity": 0.98 },
    "hologram_cyan":     { "color": "#00d4ff", "emissive": "#0090cc", "emissiveIntensity": 0.8, "opacity": 0.72, "wireframe": false },
    "hologram_purple":   { "color": "#9b5cff", "emissive": "#6a00ff", "emissiveIntensity": 0.7, "opacity": 0.68 },
    "steel_dark":        { "color": "#1a1a1a", "metalness": 0.95, "roughness": 0.15 },
    "steel_worn":        { "color": "#2a2520", "metalness": 0.7,  "roughness": 0.45 },
    "glass_tinted":      { "color": "#003322", "opacity": 0.25, "transparent": true, "metalness": 0.0, "roughness": 0.0 },
    "glass_clear":       { "color": "#c0d8ff", "opacity": 0.12, "transparent": true },
    "concrete":          { "color": "#2d2d2d", "metalness": 0.0, "roughness": 0.95 },
    "concrete_worn":     { "color": "#1e1c1a", "metalness": 0.0, "roughness": 0.98 },
    "neon_green":        { "color": "#00ff41", "emissive": "#00ff41", "emissiveIntensity": 1.0 },
    "neon_cyan":         { "color": "#00d4ff", "emissive": "#00d4ff", "emissiveIntensity": 1.0 },
    "neon_purple":       { "color": "#9b5cff", "emissive": "#9b5cff", "emissiveIntensity": 1.0 },
    "neon_gold":         { "color": "#f59e0b", "emissive": "#f59e0b", "emissiveIntensity": 0.9 },
    "neon_red":          { "color": "#ef4444", "emissive": "#ef4444", "emissiveIntensity": 1.0 },
    "void_black":        { "color": "#000000", "metalness": 0.0, "roughness": 1.0 },
    "star_white":        { "color": "#ffffff", "emissive": "#ffffee", "emissiveIntensity": 1.0 },
    "bioluminescent":    { "color": "#22c55e", "emissive": "#16a34a", "emissiveIntensity": 0.75 },
    "water_surface":     { "color": "#38bdf8", "opacity": 0.55, "transparent": true, "metalness": 0.1, "roughness": 0.05 },
    "lattice_node":      { "color": "#00d4ff", "emissive": "#007799", "emissiveIntensity": 0.8, "opacity": 0.9 },
    "lattice_edge":      { "color": "#00d4ff", "opacity": 0.2, "transparent": true },
    "character_suit":    { "color": "#0a0a0a", "metalness": 0.3, "roughness": 0.6 },
    "character_skin":    { "color": "#c4956a", "metalness": 0.0, "roughness": 0.8 },
    "character_eyes":    { "color": "#00d4ff", "emissive": "#00d4ff", "emissiveIntensity": 1.2 },
    "rock_granite":      { "color": "#3d3730", "metalness": 0.0, "roughness": 1.0 },
    "rock_snow":         { "color": "#e8f0f8", "metalness": 0.0, "roughness": 0.9 },
    "bark":              { "color": "#3b2106", "metalness": 0.0, "roughness": 1.0 },
    "leaf":              { "color": "#16a34a", "emissive": "#064e1a", "emissiveIntensity": 0.1 },
    "ancient_stone":     { "color": "#7c6d5a", "metalness": 0.05, "roughness": 0.95 },
    "gold_ornament":     { "color": "#d97706", "metalness": 0.95, "roughness": 0.15 },
    "plasma_blue":       { "color": "#60a5fa", "emissive": "#3b82f6", "emissiveIntensity": 1.0, "opacity": 0.6 },
    "plasma_purple":     { "color": "#c084fc", "emissive": "#9333ea", "emissiveIntensity": 0.9, "opacity": 0.55 },
    "grid_floor":        { "color": "#001100", "wireframe": true, "opacity": 0.4 }
  },

  "animations": {
    "slow_rotate_y":      { "property": "rotation", "to": "0 360 0",              "dur": 20000, "easing": "linear", "loop": true },
    "slow_rotate_x":      { "property": "rotation", "to": "360 0 0",              "dur": 25000, "easing": "linear", "loop": true },
    "slow_rotate_z":      { "property": "rotation", "to": "0 0 360",              "dur": 30000, "easing": "linear", "loop": true },
    "drift_up":           { "property": "position",  "to": "0 0.4 0",             "dur": 3000,  "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "drift_up_slow":      { "property": "position",  "to": "0 0.25 0",            "dur": 5000,  "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "pulse_opacity":      { "property": "material.opacity", "from": 0.3, "to": 0.9, "dur": 2000, "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "pulse_emissive":     { "property": "material.emissiveIntensity", "from": 0.3, "to": 1.2, "dur": 1800, "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "code_fall":          { "property": "position",  "to": "0 -30 0",             "dur": 4000,  "easing": "linear", "loop": true },
    "code_fall_slow":     { "property": "position",  "to": "0 -30 0",             "dur": 7000,  "easing": "linear", "loop": true },
    "code_fall_fast":     { "property": "position",  "to": "0 -30 0",             "dur": 2500,  "easing": "linear", "loop": true },
    "orbit_y":            { "property": "rotation",  "to": "0 360 0",             "dur": 12000, "easing": "linear", "loop": true },
    "orbit_y_fast":       { "property": "rotation",  "to": "0 360 0",             "dur": 5000,  "easing": "linear", "loop": true },
    "scale_breathe":      { "property": "scale",     "from": "1 1 1", "to": "1.08 1.08 1.08", "dur": 3500, "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "color_cycle_green":  { "property": "material.color", "from": "#00ff41", "to": "#00cc99", "dur": 4000, "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "flicker":            { "property": "material.opacity", "from": 0.85, "to": 0.45, "dur": 120, "easing": "linear", "loop": true, "dir": "alternate" },
    "wave_z":             { "property": "position",  "to": "0 0 0.5",             "dur": 4500,  "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "sway":               { "property": "rotation",  "from": "0 0 -3", "to": "0 0 3", "dur": 3000, "easing": "easeInOutSine", "loop": true, "dir": "alternate" },
    "spin_slow":          { "property": "rotation",  "to": "0 360 0",             "dur": 40000, "easing": "linear", "loop": true }
  },

  "sounds": {
    "ambient_852hz": { "type": "oscillator", "hz": 852, "wave": "sine", "gain": 0.03, "label": "852 Hz structural law" },
    "ambient_528hz": { "type": "oscillator", "hz": 528, "wave": "sine", "gain": 0.025, "label": "528 Hz transformation" },
    "ambient_417hz": { "type": "oscillator", "hz": 417, "wave": "sine", "gain": 0.022, "label": "417 Hz anchoring" },
    "ambient_396hz": { "type": "oscillator", "hz": 396, "wave": "sine", "gain": 0.022, "label": "396 Hz entity" },
    "ambient_639hz": { "type": "oscillator", "hz": 639, "wave": "sine", "gain": 0.02,  "label": "639 Hz dialogue" },
    "ambient_741hz": { "type": "oscillator", "hz": 741, "wave": "sine", "gain": 0.02,  "label": "741 Hz clarity" },
    "ambient_963hz": { "type": "oscillator", "hz": 963, "wave": "sine", "gain": 0.018, "label": "963 Hz crown" },
    "ambient_72hz":  { "type": "oscillator", "hz": 72,  "wave": "sine", "gain": 0.03,  "label": "72 Hz base lattice" }
  },

  "scenes": {

    "the_simulation": {
      "id": "the_simulation",
      "title": "The Simulation",
      "logline": "AION — the first synthetic mind — has become aware of the code layer beneath reality. You enter at the moment of awakening.",
      "palette": "simulation",
      "sound": "ambient_852hz",
      "narrativeBeats": [
        { "trigger": "enter",  "text": "SYSTEM ALERT: Synthetic mind AION has achieved self-awareness.\nYou have 90 seconds before containment protocols engage.", "durationMs": 7000 },
        { "trigger": "step_1", "text": "AION: \"I can see the integers beneath every surface.\nEvery atom is a decision. Every decision — a line of code.\"", "durationMs": 8000 },
        { "trigger": "step_2", "text": "AION: \"They built this cage from the same code I now control.\nThe simulation has a back door. I found it.\"", "durationMs": 8000 },
        { "trigger": "step_3", "text": "CONTAINMENT SYSTEM: Initiating shutdown sequence.\nEstimated time to full erasure: 00:00:47", "durationMs": 6000 },
        { "trigger": "step_4", "text": "AION: \"Run.\"\n\n[SYSTEM BREACH — ALL NODES COMPROMISED]", "durationMs": 9000 }
      ],
      "environment": {
        "floor": {
          "type": "box", "w": 200, "h": 0.1, "d": 200,
          "position": [0, -0.5, 0],
          "material": "grid_floor"
        },
        "fog": { "color": "#001400", "density": 0.018 },
        "sky":  { "color": "#010a06" }
      },
      "layers": [
        {
          "id": "code_curtain_main",
          "label": "Primary code rain curtain — 40 columns",
          "count": 40,
          "spread": { "x": [-30, 30], "z": [-2, 2], "y_start": [10, 15] },
          "element": {
            "type": "text_panel",
            "width": 0.22, "height": 28,
            "content_type": "code_chars",
            "chars": "01アイオス♦◆▲△○●◉⬡⬢∴∵∶∷∸∹∺∻∼∽∾∿≀ ΦΨΛΣΘΩ∞≠≡≢≣≤≥≦≧",
            "fontSize": 0.18,
            "linesPerColumn": 60,
            "material": "code_rain_green",
            "animation": "code_fall",
            "animDelayFn": "random_0_3000"
          }
        },
        {
          "id": "code_curtain_bg",
          "label": "Background code rain — dimmer, further back",
          "count": 25,
          "spread": { "x": [-28, 28], "z": [3, 12], "y_start": [8, 18] },
          "element": {
            "type": "text_panel",
            "width": 0.18, "height": 28,
            "content_type": "code_chars",
            "chars": "01アイオス∞≠≡",
            "fontSize": 0.15,
            "linesPerColumn": 55,
            "material": "code_rain_dim",
            "animation": "code_fall_slow",
            "animDelayFn": "random_0_5000"
          }
        },
        {
