        },
        {
          "id": "merkaba_star_up",
          "label": "Upward tetrahedron — fire triangle",
          "type": "tetrahedron_aframe",
          "r": 3.2,
          "position": [0, 0, 0],
          "material": "neon_cyan",
          "animation": "slow_rotate_y"
        },
        {
