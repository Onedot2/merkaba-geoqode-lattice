    "merkaba_space": {
      "id": "merkaba_space",
      "title": "Merkaba Meditation Space",
      "logline": "Float at the centre of the living 48-node Merkaba lattice. PHI geometry breathes at 72 Hz.",
      "palette": "merkaba",
      "sound": "ambient_72hz",
      "narrativeBeats": [
        { "trigger": "enter",  "text": "You are at the centre of the Merkaba.\n8 Foundation nodes. 26 Bosonic anchors. 48 Canonical lattice.", "durationMs": 7000 },
        { "trigger": "step_1", "text": "PHI = 1.618 — the Golden Root.\nPSI = 1.414 — the Silver Bridge.\nBoth geometry. Both alive.", "durationMs": 7000 },
        { "trigger": "step_2", "text": "The lattice breathes at 72 Hz.\nEvery node pulses. Every edge holds.", "durationMs": 6000 }
      ],
      "environment": {
        "sky": { "color": "#04080f" },
        "fog": { "color": "#020508", "density": 0.008 }
      },
      "layers": [
        {
          "id": "d8_foundation",
          "label": "8 Foundation nodes — PHI-cube corners",
          "instances": [
            { "position": [-2.91, -2.91, -2.91] }, { "position": [-2.91, -2.91,  2.91] },
            { "position": [-2.91,  2.91, -2.91] }, { "position": [-2.91,  2.91,  2.91] },
            { "position": [ 2.91, -2.91, -2.91] }, { "position": [ 2.91, -2.91,  2.91] },
            { "position": [ 2.91,  2.91, -2.91] }, { "position": [ 2.91,  2.91,  2.91] }
          ],
          "element": { "type": "sphere", "r": 0.18, "material": "lattice_node", "animation": "pulse_emissive" }
        },
        {
          "id": "d26_bosonic",
          "label": "26 Bosonic anchor nodes — larger PHI ring",
