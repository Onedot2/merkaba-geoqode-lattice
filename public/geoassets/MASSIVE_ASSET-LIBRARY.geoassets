            { "id": "aion_arm_l",  "type": "cylinder", "r": 0.055, "h": 0.55, "position": [-0.32, -0.72, 0], "rotation": [0, 0, 12], "material": "character_suit" },
            { "id": "aion_arm_r",  "type": "cylinder", "r": 0.055, "h": 0.55, "position": [ 0.32, -0.72, 0], "rotation": [0, 0, -12], "material": "character_suit" },
